# Copy to .env and fill in. .env is gitignored — never committed.

# Required: pick ONE of the two
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional model override (default: anthropic/claude-sonnet-4)
# Try: anthropic/claude-haiku-4-5 for cheaper, openai/gpt-4o, etc.
# FORECAST_MODEL=anthropic/claude-sonnet-4

# Optional base URL override (default: OpenRouter)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional: direct Anthropic API key for fallback when all OpenRouter models
# fail (rare). Independent infrastructure. Not used in normal operation.
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: direct OpenAI API key for the third-tier fallback (only triggered
# if BOTH OpenRouter ensemble and Anthropic direct have failed). Use a
# distinct slot from OPENAI_API_KEY (which is the OpenRouter alias).
# OPENAI_FALLBACK_API_KEY=sk-...
# OPENAI_FALLBACK_MODEL=gpt-4o
