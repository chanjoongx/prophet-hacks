# Copy to .env and fill in. .env is gitignored — never committed.

# ----- TIER 1: PRIMARY (required) -----
# OpenRouter key for the active 4-way :online ensemble. The hackathon-issued
# $50 credit key works. Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_API_KEY=sk-...     # alternative alias also accepted by get_client()

# Optional: override the OpenRouter base URL (for testing or a proxy)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional: override the OpenRouter ensemble members
# ENSEMBLE_MODEL_1=anthropic/claude-sonnet-4:online
# ENSEMBLE_MODEL_2=anthropic/claude-sonnet-4:online    # duplicate = self-consistency
# ENSEMBLE_MODEL_3=openai/gpt-4o:online
# ENSEMBLE_MODEL_4=google/gemini-2.5-flash:online

# Optional: disable the ensemble (single-model mode via FORECAST_MODEL)
# USE_ENSEMBLE=0
# FORECAST_MODEL=anthropic/claude-sonnet-4

# Optional: how many search results :online should fetch per call (default 10)
# WEB_MAX_RESULTS=10

# Optional: per-model timeout in seconds (default 20). Defends submit-endpoint
# check timeout of 25s.
# PER_MODEL_TIMEOUT_S=20

# ----- TIER 2 (FALLBACK): Anthropic direct -----
# Used ONLY when all Tier-1 ensemble calls fail. Independent infrastructure
# from OpenRouter. No web search (Anthropic Messages API has no :online).
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_FALLBACK_MODEL=claude-sonnet-4-20250514

# ----- TIER 3 (FALLBACK): OpenAI direct -----
# Used ONLY when both Tier-1 ensemble AND Tier-2 Anthropic have failed.
# Distinct slot from OPENAI_API_KEY (which is the OpenRouter alias above).
# OPENAI_FALLBACK_API_KEY=sk-...
# OPENAI_FALLBACK_MODEL=gpt-4o

# ----- EXPERIMENTAL: direct providers in active path -----
# Off by default — backtest showed direct providers (no web search) dilute
# search-grounded correct calls more than they anchor wrong ones.
# USE_DIRECT_PROVIDERS=0
# DIRECT_PROVIDER_WEIGHT=0.4
